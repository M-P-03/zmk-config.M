#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <10>; // 5 Spalten links + 5 Spalten rechts
        rows = <4>;
        map = <
        // Linke Seite                // Rechte Seite (mit Offset)
        RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)    RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)
        RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)    RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9)
        RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)    RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9)
                        RC(3,0) RC(3,1)            RC(3,5) RC(3,6)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;
        diode-direction = "col2row"; // Prüfe, ob deine Dioden zur Zeile zeigen

        row-gpios
            = <&pro_micro  7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 0 (D4)
            , <&pro_micro  8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 1 (C6)
            , <&pro_micro  9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 2 (D7)
            , <&pro_micro 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // Row 3 (E6)
            ;

        col-gpios
            = <&pro_micro 16 GPIO_ACTIVE_HIGH> // Col 0 (B1)
            , <&pro_micro 17 GPIO_ACTIVE_HIGH> // Col 1 (F7)
            , <&pro_micro 18 GPIO_ACTIVE_HIGH> // Col 2 (F6)
            , <&pro_micro 19 GPIO_ACTIVE_HIGH> // Col 3 (F5)
            , <&pro_micro 20 GPIO_ACTIVE_HIGH> // Col 4 (F4)
            ;
    };
};